{
  "name": "alarmclock-entra21",
  "version": "2.0.0",
  "description": "Aplicação web de relógio com alarmes - projeto Entra21 (refatorado com Clean Code)",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "prepare": "husky || true"
  },
  "dependencies": {
    "axios": "^0.27.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.1",
    "remove-accents": "^0.4.2"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "prettier": "^3.3.2"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "server/**/*.js"
    ],
    "coverageReporters": [
      "text",
      "text-summary",
      "lcov"
    ]
  }
}
